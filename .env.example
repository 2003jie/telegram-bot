# TG网盘机器人 v4.0 - Telegram话题版

# Telegram Bot Token（从 @BotFather 获取）
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 主群组ID（必须）
# 格式：-1001234567890
TELEGRAM_GROUP_ID=-100xxxxxxxxxx

# 话题ID（在群组中创建话题后获取）
# 获取方法：创建话题后，通过 bot API 获取 message_thread_id
VIDEO_TOPIC_ID=1      # 视频话题ID
PHOTO_TOPIC_ID=2      # 图片话题ID
DOCUMENT_TOPIC_ID=3   # 文档话题ID

# 话题创建步骤：
# 1. 在群组中点击右上角菜单 → 话题
# 2. 创建新话题：视频、图片、文档
# 3. 发送消息到话题，通过 API 获取 message_thread_id
# 4. 填入上方配置
